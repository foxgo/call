{
  "index_patterns": [
    "call_round_*"
  ],
  "template": {
    "settings": {
      "number_of_shards": 2,
      "number_of_replicas": 1,
      "refresh_interval": "30s",
      "index.lifecycle.name": "call_round_ilm",
      "index.lifecycle.rollover_alias": "call_round_write",
      "analysis": {
        "analyzer": {
          "ik_max": {
            "type": "custom",
            "tokenizer": "standard"
          }
        }
      }
    },
    "mappings": {
      "dynamic": "strict",
      "_routing": {
        "required": true
      },
      "properties": {
        "tenant_id": {
          "type": "long"
        },
        "call_id": {
          "type": "keyword"
        },
        "round_index": {
          "type": "integer"
        },
        "speaker": {
          "type": "keyword"
        },
        "content": {
          "type": "text",
          "analyzer": "ik_max"
        },
        "intent": {
          "type": "keyword"
        },
        "start_time": {
          "type": "date"
        }
      }
    }
  }
}

